# Secret key for Flask session encryption and CSRF protection
# Generate with: python3 -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY="your_secret_key_here"

# PostgreSQL database configuration
DB_NAME="flowintel"
DB_USER="flowintel"
DB_PASSWORD="your_secure_password_here"
DB_HOST="localhost"
DB_PORT=5432

# Valkey configuration
# For a direct Linux installation use 127.0.0.1.
# For Docker Compose, set this to the container name: valkey
VALKEY_PORT=6379
VALKEY_IP="127.0.0.1"

# App configuration
ENFORCE_PRIVILEGED_CASE=true
PRIVILEGED_CASE_ADD_ADMIN_ON_TASK_REQUEST=true
ENABLE_CHATBOT=false

# File uploads
FILE_UPLOAD_MAX_SIZE=5242880

# Reverse proxy
BEHIND_PROXY=true
PROXY_X_FOR=1
PROXY_X_PROTO=1
PROXY_X_HOST=1
PROXY_X_PREFIX=0

# Flask env
FLASK_ENV="production"

# Audit logging
AUDIT_LOG_PREFIX="AUDIT"
LOG_FILE="record.log"

# Application theming
MAIN_LOGO="/static/image/flowintel.png"
TOPRIGHT_LOGO=""
FOOTER_1_LOGO=""
FOOTER_2_LOGO=""
WELCOME_TEXT_TOP=""
WELCOME_TEXT_BOTTOM=""
WELCOME_LOGO=""

# GDPR
SHOW_GDPR_NOTICE=true
GDPR_NOTICE="Please be mindful of GDPR and privacy regulations when adding personal or sensitive information to cases and tasks."

# Microsoft Entra ID (Azure AD) SSO (optional)
# ENTRA_ID_ENABLED=true
# ENTRA_TENANT_ID=<your-directory-tenant-id>
# ENTRA_CLIENT_ID=<your-application-client-id>
# ENTRA_CLIENT_SECRET=<your-client-secret>
# ENTRA_REDIRECT_URL=https://<your-flowintel-host>/account/entra/callback
# ENTRA_GROUP_ADMIN=FlowintelAdmin
# ENTRA_GROUP_EDITOR=FlowintelEditor
# ENTRA_GROUP_READONLY=FlowintelReadOnly
# ENTRA_GROUP_CASE_ADMIN=FlowintelCaseAdmin
# ENTRA_ROLE_CASE_ADMIN=CaseAdmin
# ENTRA_GROUP_QUEUE_ADMIN=FlowintelQueueAdmin
# ENTRA_ROLE_QUEUE_ADMIN=QueueAdmin
# ENTRA_GROUP_QUEUER=FlowintelQueuer
# ENTRA_ROLE_QUEUER=Queuer

# Keycloak SSO (optional)
# KEYCLOAK_ENABLED=true
# KEYCLOAK_BASE_URL=https://keycloak.your-org-keycloak.com
# KEYCLOAK_REALM=flowintel
# KEYCLOAK_CLIENT_ID=flowintel
# KEYCLOAK_CLIENT_SECRET=<your-client-secret>
# KEYCLOAK_REDIRECT_URL=https://<your-flowintel-host>/account/keycloak/callback
# KEYCLOAK_GROUP_ADMIN=FlowintelAdmin
# KEYCLOAK_GROUP_EDITOR=FlowintelEditor
# KEYCLOAK_GROUP_READONLY=FlowintelReadOnly
# KEYCLOAK_GROUP_CASE_ADMIN=FlowintelCaseAdmin
# KEYCLOAK_ROLE_CASE_ADMIN=CaseAdmin
# KEYCLOAK_GROUP_QUEUE_ADMIN=FlowintelQueueAdmin
# KEYCLOAK_ROLE_QUEUE_ADMIN=QueueAdmin
# KEYCLOAK_GROUP_QUEUER=FlowintelQueuer
# KEYCLOAK_ROLE_QUEUER=Queuer


# Webhook (alerts when a new case is created)
# WEBHOOK_URL="https://example.com/webhook"
# WEBHOOK_ENABLED=false
# WEBHOOK_SECRET="your-hmac-secret"
# CASE_CREATE_ALERT_ENABLED=true

# MISP export settings
MISP_EXPORT_FILES=true

# MISP event defaults
MISP_EVENT_THREAT_LEVEL=4
MISP_EVENT_ANALYSIS=0
MISP_ADD_LOCAL_TAGS_ALL_EVENTS="curation:source=\"flowintel\""

# Central template repository
REPOSITORY_BASE_PATH="modules/repositories"

# GPG report signing (optional)
GPG_HOME=
GPG_KEY_ID=
GPG_PASSPHRASE=

# Email IMAP (archiving sent notifications)
# IMAP_SERVER="imap.gmail.com"
# IMAP_PORT=993
# IMAP_USER="your-email@example.com"
# IMAP_PASSWORD="your-app-password"
# IMAP_USE_SSL=true
