import os

from dotenv import load_dotenv
load_dotenv()


ALLOWED_DIALECT_DRIVERS = {
    "postgresql": {"psycopg2",},
    "mariadb": {"pymysql",},
    "mysql": {"pymysql",},
    "sqlite": {None, "", "pysqlite"},
}

def env_bool(name, default=False):
    """
    Parser to replace the obsoleted distutils strtobool parser:
    - Interpret "1", "true", "yes", "on", "True", "Yes", "On" as True
    - Interpret "0", "false", "no", "off", "False", "No", "Off" as False
    """
    val = os.getenv(name)
    if val is None:
        return default
    val = val.strip().lower()
    if val in {"1", "true", "yes", "on"}:
        return True
    if val in {"0", "false", "no", "off"}:
        return False
    raise ValueError(f"Invalid boolean value for {name}: {val}")

def get_db_config():
    """
    Configure these settings using environment variables or a .env file.
    Example .env file:
      DB_USER=flowintel
      DB_PASSWORD=your_secure_password_here
      DB_HOST=localhost
      DB_PORT=5432
      DB_NAME=flowintel
      DB_DIALECT=postgresql
    """
    return {
        "DIALECT": os.getenv("DB_DIALECT", "").strip().lower(),
        "DRIVER": os.getenv("DB_DRIVER", "").strip().lower(),
        "USER": os.getenv("DB_USER", "flowintel"),
        "PASSWORD": os.getenv("DB_PASSWORD", "your_secure_password_here"),
        "HOST": os.getenv("DB_HOST", "localhost"),
        "PORT": os.getenv("DB_PORT", ""),
        "NAME": os.getenv("DB_NAME", "flowintel"),
    }

def validate_db_config(dialect, driver, env_name):
    if dialect not in ALLOWED_DIALECT_DRIVERS:
        raise ValueError(f"Unsupported DB_DIALECT: {dialect}")

    if driver not in ALLOWED_DIALECT_DRIVERS[dialect]:
        raise ValueError(
            f"Invalid DB_DRIVER '{driver}' for DB_DIALECT '{dialect}' in {env_name}"
        )

    if env_name in ("testing", "production") and dialect == "sqlite":
        raise ValueError("SQLite is forbidden in production and testing")

def build_db_uri(DB, env_name):
    """
    Build SQLAlchemy connection URI.
    - PostgreSQL or MariaDB recommended for enforced and testing due to the necessity to harden production config and
    to test migrations as well as specifics around fields like JSON, VARCHARS, etc.
    - SQLite is allowed in Development and Testing only
    """
    dialect = DB['DIALECT']
    driver = DB['DRIVER']

    if not dialect:
        if env_name in ("development", "testing"):
            return "sqlite:///flowintel.sqlite"
        raise ValueError("DB_DIALECT must be set explicitely when running outside development and testing")

    validate_db_config(dialect, driver, env_name)

    if dialect == "sqlite":
        db_path = os.getenv("SQLITE_PATH", "flowintel.sqlite")
        return f"sqlite:///{db_path}"

    user = DB['USER']
    password = DB['PASSWORD']
    host = DB['HOST']
    port = DB['PORT']
    name = DB['NAME']

    if not port:
        if dialect == "postgresql":
            port = "5432"
        elif dialect in {"mariadb", "mysql"}:
            port = "3306"    

    return f"{dialect}+{driver}://{user}:{password}@{host}:{port}/{name}"

class Config():
    """
    Base configuration for Flowintel.
    """
    
    ENV_NAME = None

    # =============================================================================
    # SECRET KEY (REQUIRED)
    # =============================================================================
    # The SECRET_KEY is used for session encryption and CSRF protection.
    # Generate a strong random key using:
    #   python3 -c 'import secrets; print(secrets.token_hex(32))'
    SECRET_KEY = os.getenv('SECRET_KEY', 'SECRET_KEY_ENV_VAR_NOT_SET')
    
    # =============================================================================
    # CSRF PROTECTION
    # =============================================================================
    # CSRF token lifetime (hours). Default: 8 hours.
    # Flask-WTF expects the value in seconds via `WTF_CSRF_TIME_LIMIT`.
    WTF_CSRF_TIME_LIMIT = 8 * 3600
    
    # =============================================================================
    # FLASK APPLICATION BINDING
    # =============================================================================
    # FLASK_URL: IP address Flask binds to
    #   - Use '127.0.0.1' for local access only (recommended when behind NGINX)
    #   - Use '0.0.0.0' to allow direct access from other machines (testing only)
    # FLASK_PORT: Port number Flask listens on (default 7006)
    FLASK_URL = os.getenv('FLASK_URL', '127.0.0.1')
    FLASK_PORT = os.getenv('FLASK_PORT', '7006')

    # =============================================================================
    # MISP MODULES
    # =============================================================================
    # Address and port where MISP modules are running for analysis and enrichment
    MISP_MODULE_HOST = os.getenv('MISP_MODULE_HOST', '127.0.0.1')
    MISP_MODULE_PORT = os.getenv('MISP_MODULE_PORT', '6666')
    MISP_MODULE = f"{MISP_MODULE_HOST}:{MISP_MODULE_PORT}"
    
    # =============================================================================
    # DATABASE CONFIGURATION
    # =============================================================================
    # Connection pool settings for PostgreSQL
    SQLALCHEMY_ENGINE_OPTIONS = {"pool_pre_ping": True}

    # =============================================================================
    # SESSION STORAGE (VALKEY)
    # =============================================================================
    # Valkey is used for session management. It runs as a systemd service
    # Only change these if Valkey runs on a different host.
    VALKEY_IP = os.getenv('VALKEY_IP', '127.0.0.1')
    VALKEY_PORT = os.getenv('VALKEY_PORT', '6379')
    SESSION_TYPE = "redis" # Can be overridden in dev/test/prod class
    
    # =============================================================================
    # FILE UPLOADS
    # =============================================================================
    # Maximum file size for attachments (in bytes)
    # Remember to keep this in sync with NGINX client_max_body_size setting.
    FILE_UPLOAD_MAX_SIZE = int(os.getenv('FILE_UPLOAD_MAX_SIZE', 5 * 1024 * 1024))  # Default 5MB

    # =============================================================================
    # REVERSE PROXY
    # =============================================================================
    # SECURITY: Only enable if Flask is NOT directly accessible (firewall blocks Flask port)
    BEHIND_PROXY = env_bool('BEHIND_PROXY', default=True)
    PROXY_X_FOR = int(os.getenv('PROXY_X_FOR', 1))       # Number of proxies to trust
    PROXY_X_PROTO = int(os.getenv('PROXY_X_PROTO', 1))   # Trust X-Forwarded-Proto
    PROXY_X_HOST = int(os.getenv('PROXY_X_HOST', 1))     # Trust X-Forwarded-Host
    PROXY_X_PREFIX = int(os.getenv('PROXY_X_PREFIX', 0)) # Trust X-Forwarded-Prefix

    # =============================================================================
    # SYSTEM ROLES
    # =============================================================================
    # System roles that cannot be deleted (admin, user, bot)
    SYSTEM_ROLES = [1, 2, 3]

    # =============================================================================
    # INITIAL USER ACCOUNTS
    # =============================================================================
    # These users are created on first installation.
    # IMPORTANT: Change the admin password immediately after first login!
    INIT_ADMIN_USER = {
        "first_name": os.getenv('ADMIN_FIRST_NAME', 'admin'),
        "last_name": os.getenv('ADMIN_LAST_NAME', 'admin'),
        "email": os.getenv('ADMIN_MAIL', 'admin@admin.admin'),
        "password": os.getenv('ADMIN_PASSWORD', 'admin'),
    }
    INIT_BOT_USER = {
        "first_name": os.getenv('BOT_FIRST_NAME','Matrix'),
        "last_name": os.getenv('BOT_LAST_NAME','Bot'),
        "email": os.getenv('BOT_MAIL', 'neo@admin.admin'),
    }

    # =============================================================================
    # AUDIT LOGGING
    # =============================================================================
    # All user actions are logged to logs/record.log with the AUDIT prefix.
    AUDIT_LOG_PREFIX = os.getenv('AUDIT_LOG_PREFIX', 'AUDIT')
    LOG_FILE = os.getenv('LOG_FILE', 'record.log')
    
    # =============================================================================
    # APPLICATION THEMING
    # =============================================================================
    APP_NAME = "Flowintel"
    
    # Logo configuration
    MAIN_LOGO = os.getenv('MAIN_LOGO', '/static/image/flowintel.png')
    TOPRIGHT_LOGO = os.getenv('TOPRIGHT_LOGO', '')
    FOOTER_1_LOGO = os.getenv('FOOTER_1_LOGO', '')
    FOOTER_2_LOGO = os.getenv('FOOTER_2_LOGO', '')
    
    # Login page configuration
    WELCOME_TEXT_TOP = os.getenv('WELCOME_TEXT_TOP', '')
    WELCOME_TEXT_BOTTOM = os.getenv('WELCOME_TEXT_BOTTOM', '')
    WELCOME_LOGO = os.getenv('WELCOME_LOGO', '')
    
    # =============================================================================
    # TASK STATUS IDS
    # =============================================================================
    # Task status identifiers for workflow management
    # These IDs must match the status entries in your database
    TASK_REQUESTED = 7   # Task requested by Queuer in privileged case, pending approval
    TASK_APPROVED = 8    # Task approved by Admin/CaseAdmin/QueueAdmin
    TASK_REJECTED = 5    # Task rejected by Admin/CaseAdmin/QueueAdmin
    TASK_REQUEST_REVIEW = 9  # Task submitted for review before finishing
    
    # =============================================================================
    # ACCESS CONTROL
    # =============================================================================   
    # Limit user view to own organisation
    # When True: Users can only see other users within their own organisation
    # When False: All users can see all other users
    # Administrators always see all users regardless of this setting.
    LIMIT_USER_VIEW_TO_ORG = env_bool('LIMIT_USER_VIEW_TO_ORG', default=False)

    # =============================================================================
    # GDPR
    # =============================================================================
    # GDPR and privacy notice for case and task forms
    SHOW_GDPR_NOTICE = env_bool('SHOW_GDPR_NOTICE', default=True)
    GDPR_NOTICE = os.getenv('GDPR_NOTICE', 'Please be mindful of GDPR and privacy regulations when adding personal or sensitive information to cases and tasks.')

    # =============================================================================
    # PRIVILEGED CASE / FOUR-EYE REVIEW
    # =============================================================================
    # Privileged case enforcement
    ENFORCE_PRIVILEGED_CASE = env_bool('ENFORCE_PRIVILEGED_CASE', default=False)

    # Auto-assign Admin, Case Admin and Queue Admin to a task when it is
    # set to "Requested" or "Request Review" in a privileged case.
    # This makes the task visible in their assignment list.
    PRIVILEGED_CASE_ADD_ADMIN_ON_TASK_REQUEST = env_bool('PRIVILEGED_CASE_ADD_ADMIN_ON_TASK_REQUEST', default=False)

    # =============================================================================
    # CHATBOT
    # =============================================================================
    # Toggle the in-app chatbot (sidebar entry and /chatbot/* routes).
    # When False, the menu item is hidden and the routes return 404.
    # The chatbot also requires a reachable Ollama instance and the OLLAMA_*
    # values in conf/config_module.py before it can answer questions.
    ENABLE_CHATBOT = env_bool('ENABLE_CHATBOT', default=False)

    # =============================================================================
    # ENTRA ID
    # =============================================================================
    # Microsoft Entra ID (Azure AD) SSO configuration
    ENTRA_ID_ENABLED = env_bool('ENTRA_ID_ENABLED', default=False)
    ENTRA_TENANT_ID = os.getenv('ENTRA_TENANT_ID', '')           # Directory (tenant) ID
    ENTRA_CLIENT_ID = os.getenv('ENTRA_CLIENT_ID', '')           # Application (client) ID
    ENTRA_CLIENT_SECRET = os.getenv('ENTRA_CLIENT_SECRET', '')   # Client secret value

    # Entra ID group names that map to Flowintel roles
    # FlowintelAdmin members → provisioned as Editor, admins are notified to promote manually
    ENTRA_GROUP_ADMIN = os.getenv('ENTRA_GROUP_ADMIN', 'FlowintelAdmin')
    ENTRA_GROUP_EDITOR = os.getenv('ENTRA_GROUP_EDITOR', 'FlowintelEditor')
    ENTRA_GROUP_READONLY = os.getenv('ENTRA_GROUP_READONLY', 'FlowintelReadOnly')
    ENTRA_GROUP_CASE_ADMIN  = os.getenv('ENTRA_GROUP_CASE_ADMIN',  'FlowintelCaseAdmin')
    ENTRA_ROLE_CASE_ADMIN   = os.getenv('ENTRA_ROLE_CASE_ADMIN',   'CaseAdmin')
    ENTRA_GROUP_QUEUE_ADMIN = os.getenv('ENTRA_GROUP_QUEUE_ADMIN', 'FlowintelQueueAdmin')
    ENTRA_ROLE_QUEUE_ADMIN  = os.getenv('ENTRA_ROLE_QUEUE_ADMIN',  'QueueAdmin')
    ENTRA_GROUP_QUEUER      = os.getenv('ENTRA_GROUP_QUEUER',      'FlowintelQueuer')
    ENTRA_ROLE_QUEUER       = os.getenv('ENTRA_ROLE_QUEUER',       'Queuer')
    ENTRA_REDIRECT_URL = os.getenv('ENTRA_REDIRECT_URL', 'http://localhost:7006/account/entra/callback')

    # =============================================================================
    # KEYCLOAK
    # =============================================================================
    # Keycloak SSO configuration
    KEYCLOAK_ENABLED = env_bool('KEYCLOAK_ENABLED', default=False)
    KEYCLOAK_BASE_URL = os.getenv('KEYCLOAK_BASE_URL', '')       # e.g. https://keycloak.example.com
    KEYCLOAK_REALM = os.getenv('KEYCLOAK_REALM', 'flowintel')
    KEYCLOAK_CLIENT_ID = os.getenv('KEYCLOAK_CLIENT_ID', 'flowintel')
    KEYCLOAK_CLIENT_SECRET = os.getenv('KEYCLOAK_CLIENT_SECRET', '')

    # Keycloak group names that map to Flowintel roles
    # FlowintelAdmin members → provisioned as Editor, admins are notified to promote manually
    KEYCLOAK_GROUP_ADMIN = os.getenv('KEYCLOAK_GROUP_ADMIN', 'FlowintelAdmin')
    KEYCLOAK_GROUP_EDITOR = os.getenv('KEYCLOAK_GROUP_EDITOR', 'FlowintelEditor')
    KEYCLOAK_GROUP_READONLY = os.getenv('KEYCLOAK_GROUP_READONLY', 'FlowintelReadOnly')
    KEYCLOAK_GROUP_CASE_ADMIN  = os.getenv('KEYCLOAK_GROUP_CASE_ADMIN',  'FlowintelCaseAdmin')
    KEYCLOAK_ROLE_CASE_ADMIN   = os.getenv('KEYCLOAK_ROLE_CASE_ADMIN',   'CaseAdmin')
    KEYCLOAK_GROUP_QUEUE_ADMIN = os.getenv('KEYCLOAK_GROUP_QUEUE_ADMIN', 'FlowintelQueueAdmin')
    KEYCLOAK_ROLE_QUEUE_ADMIN  = os.getenv('KEYCLOAK_ROLE_QUEUE_ADMIN',  'QueueAdmin')
    KEYCLOAK_GROUP_QUEUER      = os.getenv('KEYCLOAK_GROUP_QUEUER',      'FlowintelQueuer')
    KEYCLOAK_ROLE_QUEUER       = os.getenv('KEYCLOAK_ROLE_QUEUER',       'Queuer')
    KEYCLOAK_REDIRECT_URL = os.getenv('KEYCLOAK_REDIRECT_URL', 'http://localhost:7006/account/keycloak/callback')

    # =============================================================================
    # MISP INTEGRATION
    # =============================================================================
    # MISP connector: attach case & task files to the MISP event
    MISP_EXPORT_FILES = env_bool('MISP_EXPORT_FILES', default=False)

    # MISP event defaults
    # Threat level: 1 = High, 2 = Medium, 3 = Low, 4 = Undefined
    MISP_EVENT_THREAT_LEVEL = int(os.getenv('MISP_EVENT_THREAT_LEVEL', '4'))

    # Analysis state: 0 = Initial, 1 = Ongoing, 2 = Complete
    MISP_EVENT_ANALYSIS = int(os.getenv('MISP_EVENT_ANALYSIS', '0'))

    # Local tags added to every MISP event created/updated by flowintel.
    # Can be a string or a list of strings. Leave empty to skip.
    # Example: 'curation:source="flowintel"' or ['tag1', 'tag2']
    MISP_ADD_LOCAL_TAGS_ALL_EVENTS = os.getenv('MISP_ADD_LOCAL_TAGS_ALL_EVENTS', 'curation:source="flowintel"')

    # =============================================================================
    # REPORT SIGNING
    # =============================================================================
    # GPG report signing (leave GPG_KEY_ID empty to disable)
    GPG_BINARY = "/usr/bin/gpg"  # Absolute path to the gpg binary
    GPG_HOME = os.getenv('GPG_HOME', '')        # Path to the GPG keyring directory (empty = default ~/.gnupg)
    GPG_KEY_ID = os.getenv('GPG_KEY_ID', '')      # Fingerprint or email of the signing key (empty = signing disabled)
    GPG_PASSPHRASE = os.getenv('GPG_PASSPHRASE', '')  # Passphrase for the key (empty = no passphrase or use gpg-agent)

    # =============================================================================
    # CENTRAL TEMPLATE REPOSITORY
    # =============================================================================
    # Central template repository
    # Base directory
    REPOSITORY_BASE_PATH = os.getenv('REPOSITORY_BASE_PATH', 'modules/repositories')

    # Manifest shown as example in "What does manifest.json look like?"
    REPOSITORY_MANIFEST = {
        "name": "My Template Repository",
        "description": "A short description of what this repository contains.",
        "uuid": "xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx",
        "version": 1
    }

    @classmethod
    def init_app(cls, app):
        # Database URI is assigned at initialisation to avoid evaluation problems at imports
        db_cfg = get_db_config()
        app.config["SQLALCHEMY_DATABASE_URI"] = build_db_uri(
            DB=db_cfg,
            env_name=app.config["ENV_NAME"]
        )


# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
# Used for local development and testing.
class DevelopmentConfig(Config):
    DEBUG = True
    ENV_NAME = "development"

    @classmethod
    def init_app(cls, app):
        super().init_app(app)
        print('THIS APP IS IN DEBUG MODE. \
                YOU SHOULD NOT SEE THIS IN PRODUCTION.')

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================
# Used for automated testing (pytest).
class TestingConfig(Config):
    TESTING = True
    WTF_CSRF_ENABLED = False
    ENV_NAME = "testing"

    @classmethod
    def init_app(cls, app):
        super().init_app(app)
        print('THIS APP IS IN TESTING MODE.  \
                YOU SHOULD NOT SEE THIS IN PRODUCTION.')

# =============================================================================
# PRODUCTION CONFIGURATION
# =============================================================================
# Used for production deployments.
class ProductionConfig(Config):
    # environment variables
    SESSION_TYPE = "redis"
    ENV_NAME = "production"

    @classmethod
    def init_app(cls, app):
        super().init_app(app)
        print('THIS APP IS IN PRODUCTION MODE.')

config = {
    'development': DevelopmentConfig,
    'testing': TestingConfig,
    'production': ProductionConfig,
    'default': DevelopmentConfig
}
