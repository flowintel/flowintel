        <mxCell id="pc_role_queuer_txt" value="&lt;b&gt;Queuer&lt;/b&gt; &amp;nbsp; &lt;font style=&quot;font-size:9px;&quot;&gt;Analyst with Queuer permission&lt;/font&gt;" style="text;html=1;fontSize=10;fontColor=#856404;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="485" y="140" width="230" height="44" as="geometry" />
        </mxCell>
        <!-- ===== FLOW NODES (180w x 72h each) ===== -->
        <!-- 1. Requested -->
        <mxCell id="pc_s1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#456297;strokeColor=#1f3763;strokeWidth=2;arcSize=8;shadow=1;container=1;collapsible=0;pointerEvents=0;" parent="1" vertex="1">
