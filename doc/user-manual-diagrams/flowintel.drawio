        </mxCell>
        <mxCell id="pc_s1_label" value="Requested" style="text;html=1;fontColor=#ffffff;fontStyle=1;fontSize=11;align=center;verticalAlign=middle;" parent="pc_s1" vertex="1">
          <mxGeometry width="180" height="22" as="geometry" />
        </mxCell>
        <mxCell id="pc_s1_desc" value="Queuer proposes a task.&lt;br&gt;Awaits approval." style="text;html=1;fontSize=9;fontColor=#495057;align=center;verticalAlign=middle;" parent="pc_s1" vertex="1">
          <mxGeometry x="4" y="24" width="172" height="44" as="geometry" />
        </mxCell>
        <!-- 2a. Approved -->
        <mxCell id="pc_s2a" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#28a745;strokeColor=#1f3763;strokeWidth=2;arcSize=8;shadow=1;container=1;collapsible=0;pointerEvents=0;" parent="1" vertex="1">
          <mxGeometry x="245" y="332" width="180" height="72" as="geometry" />
        </mxCell>
        <mxCell id="pc_s2a_body" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=none;arcSize=4;" parent="pc_s2a" vertex="1">
          <mxGeometry x="2" y="22" width="176" height="48" as="geometry" />
        </mxCell>
        <mxCell id="pc_s2a_label" value="Approved" style="text;html=1;fontColor=#ffffff;fontStyle=1;fontSize=11;align=center;verticalAlign=middle;" parent="pc_s2a" vertex="1">
          <mxGeometry width="180" height="22" as="geometry" />
        </mxCell>
        <mxCell id="pc_s2a_desc" value="Approver accepts the task.&lt;br&gt;Work can begin." style="text;html=1;fontSize=9;fontColor=#495057;align=center;verticalAlign=middle;" parent="pc_s2a" vertex="1">
          <mxGeometry x="4" y="24" width="172" height="44" as="geometry" />
        </mxCell>
        <!-- 2b. Rejected (side branch, same row as Requested) -->
        <mxCell id="pc_s2b" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dc3545;strokeColor=#1f3763;strokeWidth=2;arcSize=8;shadow=1;container=1;collapsible=0;pointerEvents=0;" parent="1" vertex="1">
          <mxGeometry x="530" y="220" width="180" height="72" as="geometry" />
        </mxCell>
        <mxCell id="pc_s2b_body" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=none;arcSize=4;" parent="pc_s2b" vertex="1">
          <mxGeometry x="2" y="22" width="176" height="48" as="geometry" />
        </mxCell>
        <mxCell id="pc_s2b_label" value="Rejected" style="text;html=1;fontColor=#ffffff;fontStyle=1;fontSize=11;align=center;verticalAlign=middle;" parent="pc_s2b" vertex="1">
          <mxGeometry width="180" height="22" as="geometry" />
        </mxCell>
        <mxCell id="pc_s2b_desc" value="Approver declines the task.&lt;br&gt;Queuer is notified." style="text;html=1;fontSize=9;fontColor=#495057;align=center;verticalAlign=middle;" parent="pc_s2b" vertex="1">
          <mxGeometry x="4" y="24" width="172" height="44" as="geometry" />
        </mxCell>
        <!-- 3. Ongoing -->
        <mxCell id="pc_s3" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d6efd;strokeColor=#1f3763;strokeWidth=2;arcSize=8;shadow=1;container=1;collapsible=0;pointerEvents=0;" parent="1" vertex="1">
          <mxGeometry x="245" y="444" width="180" height="72" as="geometry" />
        </mxCell>
        <mxCell id="pc_s3_body" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=none;arcSize=4;" parent="pc_s3" vertex="1">
          <mxGeometry x="2" y="22" width="176" height="48" as="geometry" />
        </mxCell>
        <mxCell id="pc_s3_label" value="Ongoing" style="text;html=1;fontColor=#ffffff;fontStyle=1;fontSize=11;align=center;verticalAlign=middle;" parent="pc_s3" vertex="1">
          <mxGeometry width="180" height="22" as="geometry" />
        </mxCell>
        <mxCell id="pc_s3_desc" value="Queuer works on the task.&lt;br&gt;Files, notes, subtasks." style="text;html=1;fontSize=9;fontColor=#495057;align=center;verticalAlign=middle;" parent="pc_s3" vertex="1">
          <mxGeometry x="4" y="24" width="172" height="44" as="geometry" />
        </mxCell>
        <!-- 4. Request Review -->
        <mxCell id="pc_s4" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6f42c1;strokeColor=#1f3763;strokeWidth=2;arcSize=8;shadow=1;container=1;collapsible=0;pointerEvents=0;" parent="1" vertex="1">
          <mxGeometry x="245" y="556" width="180" height="72" as="geometry" />
        </mxCell>
        <mxCell id="pc_s4_body" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=none;arcSize=4;" parent="pc_s4" vertex="1">
          <mxGeometry x="2" y="22" width="176" height="48" as="geometry" />
        </mxCell>
        <mxCell id="pc_s4_label" value="Request Review" style="text;html=1;fontColor=#ffffff;fontStyle=1;fontSize=11;align=center;verticalAlign=middle;" parent="pc_s4" vertex="1">
          <mxGeometry width="180" height="22" as="geometry" />
        </mxCell>
        <mxCell id="pc_s4_desc" value="Queuer submits finished work.&lt;br&gt;Awaits final review." style="text;html=1;fontSize=9;fontColor=#495057;align=center;verticalAlign=middle;" parent="pc_s4" vertex="1">
          <mxGeometry x="4" y="24" width="172" height="44" as="geometry" />
        </mxCell>
        <!-- 5. Finished -->
        <mxCell id="pc_s5" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#28a745;strokeColor=#1f3763;strokeWidth=2;arcSize=8;shadow=1;container=1;collapsible=0;pointerEvents=0;" parent="1" vertex="1">
          <mxGeometry x="245" y="668" width="180" height="72" as="geometry" />
        </mxCell>
        <mxCell id="pc_s5_body" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=none;arcSize=4;" parent="pc_s5" vertex="1">
          <mxGeometry x="2" y="22" width="176" height="48" as="geometry" />
        </mxCell>
        <mxCell id="pc_s5_label" value="Finished" style="text;html=1;fontColor=#ffffff;fontStyle=1;fontSize=11;align=center;verticalAlign=middle;" parent="pc_s5" vertex="1">
          <mxGeometry width="180" height="22" as="geometry" />
        </mxCell>
        <mxCell id="pc_s5_desc" value="Approver confirms the work.&lt;br&gt;Task is complete." style="text;html=1;fontSize=9;fontColor=#495057;align=center;verticalAlign=middle;" parent="pc_s5" vertex="1">
          <mxGeometry x="4" y="24" width="172" height="44" as="geometry" />
        </mxCell>
        <!-- ===== EDGES ===== -->
        <!-- Requested → Approved (straight down) -->
        <mxCell id="pc_e1" value="&lt;b&gt;Approve&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#28a745;strokeWidth=2;fontSize=9;fontColor=#28a745;endArrow=blockThin;endFill=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="pc_s1" target="pc_s2a" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Requested → Rejected (straight right) -->
        <mxCell id="pc_e2" value="&lt;b&gt;Reject&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#dc3545;strokeWidth=2;fontSize=9;fontColor=#dc3545;endArrow=blockThin;endFill=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="pc_s1" target="pc_s2b" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Approved → Ongoing (down) -->
        <mxCell id="pc_e3" value="&lt;b&gt;Work&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#0d6efd;strokeWidth=2;fontSize=9;fontColor=#0d6efd;endArrow=blockThin;endFill=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="pc_s2a" target="pc_s3" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Ongoing → Request Review (down) -->
        <mxCell id="pc_e4" value="&lt;b&gt;Submit&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#6f42c1;strokeWidth=2;fontSize=9;fontColor=#6f42c1;endArrow=blockThin;endFill=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="pc_s3" target="pc_s4" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Request Review → Finished (down) -->
        <mxCell id="pc_e5" value="&lt;b&gt;Accept&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#28a745;strokeWidth=2;fontSize=9;fontColor=#28a745;endArrow=blockThin;endFill=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="pc_s4" target="pc_s5" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Request Review → Ongoing (rework loop, right side) -->
        <mxCell id="pc_e6" value="&lt;b&gt;Rework&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#dc3545;strokeWidth=2;fontSize=9;fontColor=#dc3545;endArrow=blockThin;endFill=1;dashed=1;dashPattern=6 3;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="pc_s4" target="pc_s3" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="460" y="592" />
              <mxPoint x="460" y="480" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- ===== LEGEND ===== -->
